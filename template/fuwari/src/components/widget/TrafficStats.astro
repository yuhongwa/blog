<div
	id="traffic-stats"
	class="mt-3 border-t border-black/5 pt-3 text-center text-sm text-neutral-400 dark:border-white/10"
	aria-label="Site traffic"
	aria-live="polite"
>
	<span data-visitors>—</span> visitors
	<span aria-hidden="true">·</span>
	<span data-pageviews>—</span> views
</div>

<script>
	const stats = document.querySelector<HTMLElement>("#traffic-stats");
	const visitors = stats?.querySelector<HTMLElement>("[data-visitors]");
	const pageviews = stats?.querySelector<HTMLElement>("[data-pageviews]");

	if (stats && visitors && pageviews) {
		fetch("/api/traffic", { headers: { Accept: "application/json" } })
			.then((response) => {
				if (!response.ok) throw new Error("Traffic API unavailable");
				return response.json();
			})
			.then((data) => {
				const format = new Intl.NumberFormat();
				visitors.textContent = format.format(data.visitors);
				pageviews.textContent = format.format(data.pageviews);
			})
			.catch(() => {
				stats.hidden = true;
			});
	}
</script>
