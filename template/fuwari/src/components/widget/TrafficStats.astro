<div
	data-traffic-stats
	class="mx-auto mb-4 flex w-fit items-center gap-2 rounded-xl border border-black/5 bg-[var(--card-bg)] px-4 py-2 text-sm shadow-sm dark:border-white/10"
	aria-label="Site traffic"
	aria-live="polite"
>
	<span class="font-semibold text-[var(--primary)]">Site traffic</span>
	<span class="text-neutral-300 dark:text-neutral-600" aria-hidden="true">|</span>
	<span data-traffic-status class="text-neutral-500 dark:text-neutral-400">Loading…</span>
	<span data-traffic-values class="text-neutral-500 dark:text-neutral-400" hidden>
		<span data-visitors>—</span> visitors
		<span aria-hidden="true">·</span>
		<span data-pageviews>—</span> views
	</span>
</div>

<script>
	const statsBlocks =
		document.querySelectorAll<HTMLElement>("[data-traffic-stats]");

	if (statsBlocks.length > 0) {
		fetch("/api/traffic", { headers: { Accept: "application/json" } })
			.then((response) => {
				if (!response.ok) throw new Error("Traffic API unavailable");
				return response.json();
			})
			.then((data) => {
				const format = new Intl.NumberFormat();
				for (const stats of statsBlocks) {
					const status =
						stats.querySelector<HTMLElement>("[data-traffic-status]");
					const values =
						stats.querySelector<HTMLElement>("[data-traffic-values]");
					const visitors =
						stats.querySelector<HTMLElement>("[data-visitors]");
					const pageviews =
						stats.querySelector<HTMLElement>("[data-pageviews]");
					if (visitors) visitors.textContent = format.format(data.visitors);
					if (pageviews) pageviews.textContent = format.format(data.pageviews);
					if (status) status.hidden = true;
					if (values) values.hidden = false;
				}
			})
			.catch(() => {
				for (const stats of statsBlocks) {
					const status =
						stats.querySelector<HTMLElement>("[data-traffic-status]");
					if (status) status.textContent = "Traffic unavailable";
				}
			});
	}
</script>
