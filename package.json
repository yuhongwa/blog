{
  "name": "yuhongwa-blog",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "A content-first Fuwari blog with an isolated, updateable template.",
  "scripts": {
    "prepare:site": "node scripts/compose-site.mjs",
    "dev": "node scripts/run-site.mjs dev",
    "build": "node scripts/run-site.mjs build",
    "preview": "node scripts/run-site.mjs preview",
    "check": "node scripts/run-site.mjs check",
    "new-post": "node scripts/new-post.mjs post",
    "new:post": "node scripts/new-post.mjs post",
    "new:doc": "node scripts/new-post.mjs doc",
    "new:note": "node scripts/new-post.mjs note",
    "template:update": "node scripts/update-template.mjs"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "packageManager": "pnpm@9.14.4"
}
